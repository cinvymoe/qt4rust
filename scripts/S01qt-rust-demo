#!/bin/bash

# 如果没有参数，默认执行 start
[ -z "$1" ] && set -- start

case "$1" in
start)
    echo "Starting qt-rust-demo..."
    
    # 检查应用是否存在
    if [ -x "/userdata/local/tmp/qt-rust-demo/qt-rust-demo" ]; then
        # 使用 run.sh 启动应用
        if [ -f "/userdata/local/tmp/qt-rust-demo/run.sh" ]; then
            # 重定向输出到日志文件
            nohup sh /userdata/local/tmp/qt-rust-demo/run.sh > /userdata/local/tmp/qt-rust-demo/startup.log 2>&1 &
            echo "qt-rust-demo started (PID: $!)"
        else
            echo "Error: run.sh not found"
        fi
    else
        echo "Error: qt-rust-demo not found or not executable"
    fi
    ;;

stop)
    echo "Stopping qt-rust-demo..."
    killall qt-rust-demo
    echo "qt-rust-demo stopped"
    ;;

restart|reload)
    $0 stop
    sleep 1
    $0 start
    ;;

*)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
esac

exit 0
