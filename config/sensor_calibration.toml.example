# 起重机传感器标定配置文件示例
# 复制此文件为 sensor_calibration.toml 并根据实际情况修改
#
# 说明：
# 本文件包含所有传感器的标定参数，用于将 AD 采集值转换为物理值
# 转换公式: 物理值 = 零点物理值 + (AD值 - 零点AD) × (放大物理值 - 零点物理值) / (放大AD - 零点AD)
#
# 标定方法：
# 1. 零点标定：传感器在零点位置时，记录 AD 值和对应的物理值
# 2. 放大标定：传感器在已知物理值位置时，记录 AD 值和对应的物理值
# 3. 系统将使用这两个标定点进行线性插值，计算任意 AD 值对应的物理值

# ========== 重量传感器标定参数 ==========
# 重量传感器使用 12 位 AD 转换器（0-4095）
# 默认配置：0 AD -> 0 吨，4095 AD -> 50 吨

[weight]
# 零点 AD 值
zero_ad = 0.0
# 零点物理值（吨）
zero_value = 0.0
# 放大 AD 值（满量程）
scale_ad = 4095.0
# 放大物理值（吨）
scale_value = 50.0
# 标定倍率（1, 2, 4 或自定义值）
multiplier = 1

# ========== 角度传感器标定参数 ==========
# 角度传感器使用 12 位 AD 转换器（0-4095）
# 默认配置：0 AD -> 0 度，4095 AD -> 90 度

[angle]
# 零点 AD 值
zero_ad = 0.0
# 零点物理值（度）
zero_value = 0.0
# 放大 AD 值（满量程）
scale_ad = 4095.0
# 放大物理值（度）
scale_value = 90.0

# ========== 半径传感器标定参数 ==========
# 半径传感器使用 12 位 AD 转换器（0-4095）
# 默认配置：0 AD -> 0 米，4095 AD -> 20 米

[radius]
# 零点 AD 值
zero_ad = 0.0
# 零点物理值（米）
zero_value = 0.0
# 放大 AD 值（满量程）
scale_ad = 4095.0
# 放大物理值（米）
scale_value = 20.0